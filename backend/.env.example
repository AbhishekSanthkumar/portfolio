# ── Backend environment variables ──
# Copy this file to .env and fill in your values
# Never commit .env to git!

# Gmail address to send contact form emails FROM
EMAIL_USER=abhishek.santha1802@gmail.com

# Gmail App Password (NOT your real password)
# How to get one: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_PASS=your_16_character_app_password_here

# Your deployed frontend URL (only needed in production)
# Example: https://abhishek-portfolio.onrender.com
FRONTEND_URL=
